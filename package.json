{
  "name": "@repo/root",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many -t serve",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "type-check": "nx run-many -t type-check",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test",
    "affected:lint": "nx affected -t lint",
    "graph": "nx graph",
    "clean": "nx reset && rm -rf node_modules"
  },
  "devDependencies": {
    "@nx/js": "^19.0.0",
    "@nx/next": "^19.0.0",
    "@nx/node": "^19.0.0",
    "@nx/react": "^19.0.0",
    "@nx/react-native": "^19.0.0",
    "@nx/workspace": "^19.0.0",
    "nx": "^19.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
